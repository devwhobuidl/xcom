generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String             @id @default(cuid())
  walletAddress       String?            @unique
  email               String?            @unique
  username            String?            @unique
  password            String?
  points              Int                @default(0)
  streak              Int                @default(0)
  totalXcomEarned     Float              @default(0)
  xp                  Int                @default(0)
  rank                Int                @default(0)
  lastLogin           DateTime?          @default(now())
  referralCode        String?            @unique
  referredBy          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  bio                 String?
  image               String?
  bannerImage         String?
  bookmarks           Bookmark[]
  followers           Follow[]           @relation("following")
  following           Follow[]           @relation("follower")
  notifications       Notification[]     @relation("NotificationRecipient")
  issuedNotifications Notification[]     @relation("NotificationIssuer")
  pointsLog           PointTransaction[]
  posts               Post[]
  reactions           Reaction[]
  chatMessages        ChatMessage[]
  communityMemberships CommunityMember[]
}

model ChatChannel {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  messages    ChatMessage[]
  createdAt   DateTime      @default(now())
}

model ChatMessage {
  id        String      @id @default(cuid())
  content   String
  imageUrl  String?
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id])
  createdAt DateTime    @default(now())
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  following   User     @relation("following", fields: [followingId], references: [id])
  follower    User     @relation("follower", fields: [followerId], references: [id])

  @@unique([followerId, followingId])
}

model Post {
  id            String         @id @default(cuid())
  content       String
  imageUrl      String?
  authorId      String
  createdAt     DateTime       @default(now())
  parentId      String?
  bookmarks     Bookmark[]
  notifications Notification[]
  parent        Post?          @relation("Replies", fields: [parentId], references: [id])
  replies       Post[]         @relation("Replies")
  author        User           @relation(fields: [authorId], references: [id])
  reactions     Reaction[]
  communityId   String?
  community     Community?     @relation(fields: [communityId], references: [id])
}

model Community {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  banner      String?
  avatar      String?
  memberCount Int      @default(0)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  members     CommunityMember[]
  posts       Post[]
}

model CommunityMember {
  id          String    @id @default(cuid())
  userId      String
  communityId String
  role        String    @default("member") // member, admin
  joinedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  community   Community @relation(fields: [communityId], references: [id])
}

model Reaction {
  id     String       @id @default(cuid())
  type   ReactionType
  postId String
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  userId    String
  issuerId  String
  postId    String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  post      Post?            @relation(fields: [postId], references: [id])
  user      User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  issuer    User             @relation("NotificationIssuer", fields: [issuerId], references: [id])
}

model PointTransaction {
  id        String   @id @default(cuid())
  amount    Int
  reason    String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AirdropLog {
  id             String   @id @default(cuid())
  amount         Float
  recipientCount Int
  signature      String
  createdAt      DateTime @default(now())
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

enum ReactionType {
  LIKE
  FUCK_YOU
  REPOST
}

enum NotificationType {
  FOLLOW
  LIKE
  REPLY
  REPOST
  AIRDROP
}
